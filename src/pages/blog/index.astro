---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Articles on MLOps, Kubernetes, infrastructure, and software engineering.">
  <div class="container" style="padding-top: 3rem; padding-bottom: 3rem;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Blog</h1>
    <p style="color: var(--text-muted); margin-bottom: 3rem;">Thoughts on MLOps, infrastructure, and software engineering.</p>

    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} style="display: block; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; text-decoration: none; transition: border-color 0.2s;">
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
            <div style="flex: 1;">
              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
                {post.data.tags?.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
              <h2 style="font-size: 1.2rem; color: var(--text-heading); margin-bottom: 0.5rem;">{post.data.title}</h2>
              <p style="color: var(--text-muted); font-size: 0.9rem;">{post.data.description}</p>
            </div>
            <time style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.8rem; white-space: nowrap;" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

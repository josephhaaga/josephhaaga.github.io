---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EMAIL } from '../consts';
---

<BaseLayout title="Consulting" description="MLOps and platform engineering consulting services from Joseph Haaga.">
  <div class="container" style="padding-top: 3rem; padding-bottom: 3rem;">

    <!-- Hero -->
    <div style="margin-bottom: 4rem; padding-bottom: 3rem; border-bottom: 1px solid var(--border);">
      <div style="display: inline-block; background: rgba(6, 182, 212, 0.1); border: 1px solid var(--accent); color: var(--accent); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.85rem; font-family: var(--font-mono); margin-bottom: 1.5rem;">
        ✦ Currently accepting clients
      </div>
      <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">Consulting Services</h1>
      <p style="color: var(--text-muted); font-size: 1.15rem; max-width: 60ch;">
        I help engineering teams design, build, and scale ML infrastructure and data platforms.
        10+ years of production experience across media, fintech, and defense sectors.
      </p>
    </div>

    <!-- Services -->
    <section style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">What I Do</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem;">
        {[
          {
            icon: '🤖',
            title: 'MLOps Consulting',
            desc: 'Design and implement end-to-end ML platforms: model training pipelines, experiment tracking, model registry, and serving infrastructure.'
          },
          {
            icon: '☸️',
            title: 'Platform Engineering',
            desc: 'Kubernetes-based platform design, Helm chart authoring, internal developer platforms, and GitOps workflows.'
          },
          {
            icon: '📊',
            title: 'Data Infrastructure',
            desc: 'Build reliable data pipelines with Spark, dbt, and modern data stack tooling. Data warehouse design and optimization.'
          },
          {
            icon: '🏗️',
            title: 'ML System Design',
            desc: 'Architecture reviews, technical roadmapping, and hands-on help designing systems that scale from prototype to production.'
          }
        ].map(s => (
          <div style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem;">
            <div style="font-size: 2rem; margin-bottom: 0.75rem;">{s.icon}</div>
            <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">{s.title}</h3>
            <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Why Hire Me -->
    <section style="margin-bottom: 4rem; padding: 2rem; background: var(--bg-secondary); border-radius: 12px; border: 1px solid var(--border);">
      <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem;">Why Work With Me</h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        {[
          'Built MLOps platform at BuzzFeed powering recommendations for millions of users',
          'Led ML infrastructure team at Interos, scaling from 0 to production',
          'Senior Data Engineer at Capital One — high-compliance financial data systems',
          '10+ years shipping production software across ML, data, and full-stack',
          'Hands-on with Kubeflow, MLflow, Airflow, Spark, and the modern data stack',
          'Clear communicator — I write docs and talk to stakeholders, not just code'
        ].map(item => (
          <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
            <span style="color: var(--accent); flex-shrink: 0; margin-top: 0.1rem;">✓</span>
            <p style="color: var(--text-muted); font-size: 0.9rem;">{item}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Engagement Types -->
    <section style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">Engagement Types</h2>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
        {[
          { title: 'Part-Time Consulting', desc: '10-20 hrs/week alongside your team. Best for ongoing platform work and advisory.' },
          { title: 'Project-Based', desc: 'Fixed-scope engagements with clear deliverables. Great for audits, migrations, or new platform builds.' },
          { title: 'Full-Time Roles', desc: 'Open to staff/principal engineer opportunities at mission-driven companies.' }
        ].map(e => (
          <div style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; text-align: center;">
            <h3 style="font-size: 1.05rem; margin-bottom: 0.5rem; color: var(--accent);">{e.title}</h3>
            <p style="color: var(--text-muted); font-size: 0.88rem; line-height: 1.6;">{e.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- What You Get -->
    <section style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem;">What You Get</h2>
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        {[
          'Weekly async updates and clear documentation',
          'Production-ready code with tests, not PoC-quality throw-aways',
          'Knowledge transfer — your team will understand what was built',
          "Honest assessments, including when you don't need what you think you need",
          'Flexible communication (Slack, email, video) that fits your workflow'
        ].map(item => (
          <div style="display: flex; gap: 0.75rem; align-items: center; padding: 0.75rem 1rem; background: var(--bg-secondary); border-radius: 6px; border: 1px solid var(--border);">
            <span style="color: var(--accent);">→</span>
            <p style="color: var(--text); font-size: 0.9rem;">{item}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact Form -->
    <section style="max-width: 600px;">
      <h2 style="font-size: 1.75rem; margin-bottom: 0.5rem;">Get in Touch</h2>
      <p style="color: var(--text-muted); margin-bottom: 2rem;">Tell me about your project and I'll get back to you within 48 hours.</p>
      <form action={`mailto:${EMAIL}`} method="POST" style="display: flex; flex-direction: column; gap: 1rem;">
        <div>
          <label for="name" style="display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.4rem;">Name</label>
          <input id="name" type="text" name="name" required style="width: 100%; padding: 0.7rem 1rem; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 0.9rem;" />
        </div>
        <div>
          <label for="email" style="display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.4rem;">Email</label>
          <input id="email" type="email" name="email" required style="width: 100%; padding: 0.7rem 1rem; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 0.9rem;" />
        </div>
        <div>
          <label for="message" style="display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.4rem;">Message</label>
          <textarea id="message" name="message" rows="5" required style="width: 100%; padding: 0.7rem 1rem; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 0.9rem; resize: vertical;"></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="align-self: flex-start;">Send Message</button>
      </form>
    </section>

  </div>
</BaseLayout>

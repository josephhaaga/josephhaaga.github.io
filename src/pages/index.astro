---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const skills = [
  'Python', 'JavaScript/Node.js', 'Java', 'Scala',
  'Docker', 'Kubernetes', 'Terraform', 'AWS', 'GCP',
  'ML/MLOps', 'Kubeflow', 'TensorFlow', 'PyTorch',
  'Apache Spark', 'React', 'MongoDB', 'Elasticsearch', 'SQL'
];
---

<BaseLayout title="Home" description="Joseph Haaga - Principal Software Engineer & MLOps Consultant based in Washington D.C.">
  <!-- Hero Section -->
  <section style="padding: 5rem 0 4rem; border-bottom: 1px solid var(--border);">
    <div class="container">
      <div class="hero-grid">
        <div>
          <div style="font-family: var(--font-mono); color: var(--accent); margin-bottom: 1rem; font-size: 0.9rem;">$ whoami</div>
          <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 0.75rem; line-height: 1.1;">Joseph Haaga</h1>
          <h2 style="font-size: clamp(1rem, 2.5vw, 1.35rem); color: var(--text-muted); font-weight: 400; margin-bottom: 1.5rem;">
            Principal Software Engineer & MLOps Consultant
          </h2>
          <p style="font-size: 1.1rem; color: var(--text-muted); margin-bottom: 2rem; max-width: 50ch;">
            Building scalable ML systems and infrastructure. Based in Washington, D.C.
          </p>
          <div style="display: inline-block; background: rgba(6, 182, 212, 0.1); border: 1px solid var(--accent); color: var(--accent); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.85rem; font-family: var(--font-mono); margin-bottom: 2rem;">
            ✦ Currently available for consulting
          </div>
          <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="/consulting" class="btn btn-primary">Hire Me</a>
            <a href="/resume" class="btn btn-outline">View Resume</a>
          </div>
        </div>
        <div class="hero-image">
          <img src="/me.jpg" alt="Joseph Haaga" style="width: 220px; height: 220px; border-radius: 50%; object-fit: cover; border: 3px solid var(--accent); box-shadow: 0 0 30px rgba(6, 182, 212, 0.2);" />
        </div>
      </div>
    </div>
  </section>

  <!-- Terminal Section -->
  <section style="padding: 3rem 0; border-bottom: 1px solid var(--border);">
    <div class="container">
      <div style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; max-width: 700px;">
        <div style="background: #0d1117; padding: 0.75rem 1rem; display: flex; gap: 0.5rem; align-items: center;">
          <span style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f57; display: inline-block;"></span>
          <span style="width: 12px; height: 12px; border-radius: 50%; background: #febc2e; display: inline-block;"></span>
          <span style="width: 12px; height: 12px; border-radius: 50%; background: #28c840; display: inline-block;"></span>
          <span style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.8rem; margin-left: 0.5rem;">terminal</span>
        </div>
        <div style="padding: 1.5rem; font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.8;">
          <p><span style="color: var(--accent);">joe@dc</span><span style="color: var(--text-muted);">:~$</span> cat skills.txt</p>
          <p style="color: var(--text-muted); margin-top: 0.5rem;">Languages: Python, JavaScript, Java, Scala</p>
          <p style="color: var(--text-muted);">Cloud:     AWS, GCP</p>
          <p style="color: var(--text-muted);">MLOps:     Kubeflow, MLflow, TensorFlow, PyTorch</p>
          <p style="color: var(--text-muted);">Infra:     Kubernetes, Docker, Terraform</p>
          <p style="color: var(--text-muted);">Data:      Spark, Elasticsearch, MongoDB, SQL</p>
          <p style="margin-top: 0.5rem;"><span style="color: var(--accent);">joe@dc</span><span style="color: var(--text-muted);">:~$</span> <span style="animation: blink 1s step-end infinite; color: var(--text-heading);">█</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section style="padding: 4rem 0; border-bottom: 1px solid var(--border);">
    <div class="container">
      <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">About</h2>
      <div class="about-grid">
        <div class="prose">
          <p>I'm a Principal Software Engineer and MLOps specialist with 10+ years of experience building production ML systems and data infrastructure at scale.</p>
          <p>Currently at <strong style="color: var(--text-heading);">BuzzFeed</strong>, where I architect and maintain ML platforms that power content recommendations and analytics for millions of users.</p>
          <p>Previously built ML infrastructure at <strong style="color: var(--text-heading);">Interos</strong>, led data engineering at <strong style="color: var(--text-heading);">Capital One</strong>, and built data science systems at <strong style="color: var(--text-heading);">Redhorse Corporation</strong>.</p>
        </div>
        <div class="prose">
          <p>Based in <strong style="color: var(--text-heading);">Washington, D.C.</strong>, I specialize in:</p>
          <ul>
            <li>ML platform design and MLOps tooling</li>
            <li>Kubernetes-based ML infrastructure</li>
            <li>Data pipeline architecture</li>
            <li>Cloud infrastructure (AWS, GCP)</li>
            <li>Platform engineering for data teams</li>
          </ul>
          <p>I'm available for consulting engagements, advisory roles, and full-time opportunities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Grid -->
  <section style="padding: 4rem 0; border-bottom: 1px solid var(--border);">
    <div class="container">
      <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">Tech Stack</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
        {skills.map(skill => (
          <span style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text); padding: 0.4rem 1rem; border-radius: 6px; font-family: var(--font-mono); font-size: 0.85rem; transition: border-color 0.2s; cursor: default;">
            {skill}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <section style="padding: 4rem 0; border-bottom: 1px solid var(--border);">
    <div class="container">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
        <h2 style="font-size: 1.75rem;">Latest Posts</h2>
        <a href="/blog" style="color: var(--accent); font-size: 0.9rem;">View all →</a>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
        {posts.map(post => (
          <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} style="display: block; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; text-decoration: none; transition: border-color 0.2s;">
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.75rem;">
              {post.data.tags?.slice(0, 2).map((tag: string) => <span class="tag">{tag}</span>)}
            </div>
            <h3 style="font-size: 1rem; color: var(--text-heading); margin-bottom: 0.5rem; line-height: 1.4;">{post.data.title}</h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.75rem; line-height: 1.5;">{post.data.description}</p>
            <time style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.8rem;" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding: 5rem 0;">
    <div class="container" style="text-align: center;">
      <h2 style="font-size: 2rem; margin-bottom: 1rem;">Let's Work Together</h2>
      <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 2rem; max-width: 50ch; margin-left: auto; margin-right: auto;">
        Available for consulting engagements, architecture reviews, and full-time roles.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/consulting" class="btn btn-primary">Hire Me</a>
        <a href="/resume" class="btn btn-outline">View Resume</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }

  .hero-image {
    display: flex;
    justify-content: center;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 640px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-image {
      order: -1;
    }

    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

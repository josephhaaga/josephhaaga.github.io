---
import '../styles/global.css';
import { SITE_TITLE, GITHUB, LINKEDIN, EMAIL } from '../consts';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Joseph Haaga - Principal Software Engineer & MLOps Consultant' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | {SITE_TITLE}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" />
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a href="/" class="nav-brand">~/josephhaaga</a>
        <ul class="nav-links">
          <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a></li>
          <li><a href="/blog" class:list={[{ active: currentPath.startsWith('/blog') }]}>Blog</a></li>
          <li><a href="/consulting" class:list={[{ active: currentPath === '/consulting' }]}>Consulting</a></li>
          <li><a href="/resume" class:list={[{ active: currentPath === '/resume' }]}>Resume</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <p style="color: var(--text-muted); font-size: 0.85rem;">© 2024 Joseph Haaga. Built with Astro.</p>
        <div class="footer-links">
          <a href={`https://github.com/${GITHUB}`} target="_blank" rel="noopener">GitHub</a>
          <a href={`https://linkedin.com/in/${LINKEDIN}`} target="_blank" rel="noopener">LinkedIn</a>
          <a href={`mailto:${EMAIL}`}>Email</a>
        </div>
      </div>
    </footer>
  </body>
</html>
